# Required for Prisma database commands and any persistence-backed feature.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/neorate?schema=public"

# Optional: debug | info | warn | error (default: info)
LOG_LEVEL="info"

# Experimental and disabled by default. Only exact lowercase "true" enables Revolut.
# Missing, empty, or any other value safely disables it.
REVOLUT_ADAPTER_ENABLED="false"

# Experimental and disabled by default. Only exact lowercase "true" enables ZEN Pro.
# Server-side cookie-free access must be verified in the target environment before enabling.
ZEN_ADAPTER_ENABLED="false"

# Enables only the explicit manual Revolut probe; normal tests never call Revolut.
REVOLUT_LIVE_TEST_ENABLED="false"
